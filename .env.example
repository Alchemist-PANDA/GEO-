# ──────────────────────────────────────
# BrandSight GEO — Environment Variables
# ──────────────────────────────────────
# Copy to .env and fill in values.

# ── App Mode ──
FORCE_MOCK=true                     # Set to "true" for offline demo mode (no API keys needed)

# ── Dashboard/Auth ──
SUPABASE_URL=                       # Required to enable authenticated live UI
SUPABASE_ANON_KEY=                  # Public anon key; never use service_role in Streamlit
BRANDSIGHT_ADMIN_EMAILS=            # Comma-separated verified Supabase admin emails

# ── Database ──
DATABASE_URL=postgresql://geo_app:changeme@localhost:5432/geo_saas
POSTGRES_USER=geo_app
POSTGRES_PASSWORD=changeme          # REQUIRED for Docker Compose

# ── Redis ──
REDIS_URL=redis://:changeme@localhost:6379/0
REDIS_PASSWORD=changeme             # REQUIRED for Docker Compose

# ── Vector Search (Qdrant) ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                     # Optional, for Qdrant Cloud

# ── LLM Providers ──
ANTHROPIC_API_KEY=                  # Claude API key
ANTHROPIC_BASE_URL=                 # Optional proxy URL
ANTHROPIC_AUTH_TOKEN=               # Optional auth token
GOOGLE_API_KEY=                     # Gemini primary key; never commit a real value
# Optional validation-only cold backups. The harness uses GOOGLE_API_KEY first and
# will not rotate unless --allow-key-failover is explicitly supplied.
GOOGLE_API_KEY_1=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY_4=
GOOGLE_API_KEY_5=
GOOGLE_API_KEY_6=
GOOGLE_API_KEY_7=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_MAX_OUTPUT_TOKENS=512
GEMINI_VALIDATION_MAX_REQUESTS=4
OPENAI_API_KEY=                     # ChatGPT API key
PERPLEXITY_API_KEY=                 # Perplexity API key

# ── Observability (Langfuse) ──
LANGFUSE_PUBLIC_KEY=                # Optional, tracing disabled if unset
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Memory (Mem0) ──
MEM0_BACKEND=qdrant                 # "qdrant" or "redis"

# ── Monitoring ──
GRAFANA_PASSWORD=changeme           # REQUIRED for Docker Compose

# ── Agentic System Limits ──
AGENTIC_MAX_TOKENS_PER_REQUEST=8000
AGENTIC_DAILY_USD_BUDGET=50.0

# ── App Security ──
API_SECRET_KEY=                     # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SUPABASE_JWT_SECRET=                # JWT secret for API auth
SUPABASE_JWT_AUDIENCE=authenticated  # Recommended Supabase audience validation
SUPABASE_JWT_ISSUER=                # Optional: https://<project>.supabase.co/auth/v1
NEXTAUTH_SECRET=                    # Required by self-hosted Langfuse
SALT=                               # Required by self-hosted Langfuse
