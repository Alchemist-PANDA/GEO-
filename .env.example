# LLM API Configuration
# Configure at least one provider for live API mode

# Google Gemini (optional)
GOOGLE_API_KEY=your-google-api-key-here

# Groq (recommended for fast inference)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Legacy configuration (optional)
ANTHROPIC_BASE_URL=http://localhost:20128/v1
ANTHROPIC_AUTH_TOKEN=sk_9router

# App Security
API_SECRET_KEY=dev_default_key

# Note: If no API keys are configured, the app runs in Simulated Demo Mode

# Agentic AI system environment variables
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here (already above)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
MEM0_BACKEND=qdrant
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://user:pass@postgres:5432/brandsight
AGENTIC_MAX_TOKENS_PER_REQUEST=120000
AGENTIC_DAILY_USD_BUDGET=50
FORCE_MOCK=false

APP_URL=http://localhost:8501
